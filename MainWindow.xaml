        <Border x:Name="ProgressBorder" Grid.Row="3" Background="#FF1F1F1F" CornerRadius="6" Padding="10" Margin="0,0,19,10" Grid.ColumnSpan="2">
            <StackPanel>
                <TextBlock x:Name="PartInfoTextBlock" FontSize="14" FontWeight="Bold" Foreground="Yellow" HorizontalAlignment="Center" Margin="0,0,0,5"/>
                <ProgressBar x:Name="DownloadProgressBar" x:FieldModifier="public" Height="20" Margin="0,0,0,10" Style="{StaticResource RoundedProgressBarStyle}" Background="#FF3E3E3E" Foreground="#FF005FB8"/>
                <TextBlock x:Name="SpeedTextBlock" FontSize="13" FontWeight="Bold" Foreground="Cyan" HorizontalAlignment="Center" Margin="0,0,0,5"/>
                <TextBlock x:Name="ProgressTextBlock" FontSize="13" Foreground="#FFCCCCCC" HorizontalAlignment="Center" Margin="0,0,0,5" FontWeight="Bold"/>
                <TextBlock x:Name="SecondaryProgressTextBlock" FontSize="12" Foreground="#FF999999" HorizontalAlignment="Center" Margin="0,0,0,10" FontStyle="Italic"/>
                <!-- Connection trace canvas: shows per-connection segments and active connection count -->
                <Grid Margin="0,8,0,0">
                    <StackPanel>
                        <!-- Build number (left) | Segments (center) -->
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,4">
                            <TextBlock x:Name="BuildNumberTextBlock" Text="Build: ----" FontSize="12" Foreground="#FFF0F0F0" VerticalAlignment="Center" Margin="0,0,16,0"/>
                            <TextBlock Text="|" FontSize="12" Foreground="#FF666666" VerticalAlignment="Center" Margin="0,0,16,0"/>
                            <TextBlock Text="Segments:" FontSize="11" Foreground="#FFF0F0F0" VerticalAlignment="Center" Margin="0,0,6,0"/>
                            <ComboBox x:Name="CboSegmentCount" Width="72" Height="20" FontSize="11" SelectedValuePath="Content" PreviewMouseWheel="CboSegmentCount_PreviewMouseWheel" SelectionChanged="CboSegmentCount_SelectionChanged">
                                <ComboBoxItem Content="1" />
                                <ComboBoxItem Content="2" />
                                <ComboBoxItem Content="4" />
                                <ComboBoxItem Content="8" />
                                <ComboBoxItem Content="16" IsSelected="True" />
                            </ComboBox>
                        </StackPanel>
                        <!-- Connection trace bar fills the full width below -->
                        <Border x:Name="ConnectionTraceBorder" CornerRadius="4" ClipToBounds="True" Background="#FF2B2B2B" Height="18">
                            <UniformGrid x:Name="ConnectionTraceGrid" Rows="1" HorizontalAlignment="Stretch"/>
                        </Border>
                    </StackPanel>
                    <TextBlock x:Name="ConnectionCountTextBlock" FontSize="11" Foreground="#FFF0F0F0" HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,0,4,0"/>
                </Grid>
            </StackPanel>
        </Border>

    </Grid>
</Window>
