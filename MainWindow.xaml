                    <Button x:Name="BtnStop" Content="Stop" Width="45" Height="28" Background="#FFB80000" BorderBrush="#FFB80000" Click="BtnStop_Click" IsEnabled="False"/>
                    <Button x:Name="BtnRefreshColor" Content="Refresh Color" Width="84" Height="28" Background="DarkMagenta" BorderBrush="DarkCyan" Click="BtnRefreshColor_Click"/>
