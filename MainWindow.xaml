                                        <Style TargetType="{x:Type ComboBoxItem}">
                                            <Setter Property="HorizontalContentAlignment" Value="Left"/>
                                            <Setter Property="VerticalContentAlignment" Value="Center"/>
                                        </Style>
                                    </ComboBox.ItemContainerStyle>
                                </ComboBox>
                            </StackPanel>
                            <Button x:Name="BtnOpenFolder" Content="Open folder" Width="75" Height="22" Margin="0,3,3,3" Background="DarkCyan" BorderBrush="darkcyan" Click="BtnOpenFolder_Click" VerticalAlignment="Bottom"/>
