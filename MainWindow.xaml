<!-- AI Summary: 2026-04-23 - Added spacing between CPU/RAM entries and distinct accent colors for System Information panels -->
<!-- AI Summary: 2026-04-24 - Added ChkDownloadSampleVideo to the Subtitle tab -->
<!-- AI Summary: 2026-04-25 - Moved build number display to the top for all tabs, removed Edge workspace button, and added Brave browser checkbox -->
<Window x:Class="GMTPC.Tool.MainWindow"
         xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
         xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
         Title="GMTPC Tools" SizeToContent="WidthAndHeight" MinHeight="480" MinWidth="560" MaxHeight="800" MaxWidth="1000"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanResizeWithGrip"
        WindowStyle="SingleBorderWindow"
        Background="#FF0F0F0F" PreviewKeyDown="Window_KeyDown" PreviewMouseWheel="Window_MouseWheel" Loaded="Window_Loaded" SourceInitialized="Window_SourceInitialized" SizeChanged="Window_SizeChanged" Width="581">
    <Window.Resources>
        <Style TargetType="CheckBox">
            <Setter Property="Foreground" Value="#FFE6E6E6"/>
            <Setter Property="FontSize" Value="9.5"/>
            <Setter Property="Height" Value="27"/>
            <Setter Property="Margin" Value="2,1"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CheckBox">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Border x:Name="checkBoxBorder" 
                                    Grid.Column="0"
                                    Width="18" 
                                    Height="18" 
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="#FF7A7A7A" 
                                    BorderThickness="1.5"
                                    CornerRadius="5"
                                    Margin="0,0,6,0">
                                <Path x:Name="checkMark"
                                      Data="M 4 8 L 8 12 L 16 4"
                                      Stroke="#FFFFFFFF"
                                      StrokeThickness="2"
                                      Stretch="Uniform"
                                      HorizontalAlignment="Center"
                                      VerticalAlignment="Center"
                                      Visibility="Collapsed"/>
                            </Border>
                            <ContentPresenter x:Name="contentPresenter"
                                              Grid.Column="1"
                                              Content="{TemplateBinding Content}"
                                              VerticalAlignment="Center"
                                              Margin="2,0,0,0"/>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="checkMark" Property="Visibility" Value="Visible"/>
                                <Setter TargetName="checkBoxBorder" Property="Background" Value="#FF005FB8"/>
                                <Setter TargetName="checkBoxBorder" Property="BorderBrush" Value="#FF005FB8"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="checkBoxBorder" Property="BorderBrush" Value="#FFCCCCCC"/>
                            </Trigger>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter TargetName="checkBoxBorder" Property="BorderBrush" Value="Cyan"/>
                            </Trigger>
                            <Trigger Property="IsKeyboardFocused" Value="True">
                                <Setter TargetName="checkBoxBorder" Property="BorderBrush" Value="Cyan"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style TargetType="Button">
            <Setter Property="Background" Value="#FF2B2B2B"/>
            <Setter Property="Foreground" Value="#FFE6E6E6"/>
            <Setter Property="BorderBrush" Value="#FF7A7A7A"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="8,3"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" 
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4">
                            <ContentPresenter x:Name="contentPresenter" 
                                              HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#FF3E3E3E"/>
                                <Setter TargetName="border" Property="BorderBrush" Value="#FFCCCCCC"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#FF005FB8"/>
                                <Setter TargetName="border" Property="BorderBrush" Value="#FF005FB8"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <!-- Style tùy chỉnh cho ProgressBar với bo tròn -->
        <Style x:Key="RoundedProgressBarStyle" TargetType="ProgressBar">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ProgressBar">
                        <Grid>
                            <Border x:Name="PART_Track"
                                    Background="{TemplateBinding Background}"
                                    CornerRadius="4"/>
                            <Border x:Name="PART_Indicator"
                                    Background="{TemplateBinding Foreground}"
                                    HorizontalAlignment="Left"
                                    CornerRadius="4"/>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Style cho Theme Toggle Switch -->
        <Style x:Key="ThemeToggleSwitchStyle" TargetType="ToggleButton">
            <Setter Property="Width" Value="34"/>
            <Setter Property="Height" Value="18"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Grid>
                            <!-- Background track -->
                            <Border x:Name="track"
                                    Width="34" Height="18"
                                    CornerRadius="9"
                                    Background="#FF555555">
                                <Border x:Name="thumb"
                                        Width="14" Height="14"
                                        CornerRadius="7"
                                        Background="#FF888888"
                                        HorizontalAlignment="Left"
                                        Margin="2,0,0,0">
                                    <Border.Effect>
                                        <DropShadowEffect BlurRadius="3" ShadowDepth="0" Opacity="0.3"/>
                                    </Border.Effect>
                                </Border>
                            </Border>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="track" Property="Background" Value="#FF00AA00"/>
                                <Setter TargetName="thumb" Property="Background" Value="#FF00FF00"/>
                                <Setter TargetName="thumb" Property="HorizontalAlignment" Value="Right"/>
                                <Setter TargetName="thumb" Property="Margin" Value="0,0,2,0"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="track" Property="BorderBrush" Value="#FFCCCCCC"/>
                                <Setter TargetName="track" Property="BorderThickness" Value="1"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>
    <Grid Margin="15" x:Name="MainGrid" Background="#FF0F0F0F">
        <Grid.Resources>
            <!-- Định nghĩa Style cho WrapPanel responsive -->
            <Style x:Key="ResponsiveWrapPanelStyle" TargetType="WrapPanel">
                <Setter Property="Orientation" Value="Horizontal"/>
                <Style.Triggers>
                    <!-- Khi chiều rộng nhỏ hơn chiều cao (chế độ dọc), đổi sang dọc -->
                    <DataTrigger Binding="{Binding ActualWidth, RelativeSource={RelativeSource AncestorType=Window}}" Value="300">
                        <Setter Property="Orientation" Value="Vertical"/>
                    </DataTrigger>
                    <DataTrigger Binding="{Binding ActualWidth, RelativeSource={RelativeSource AncestorType=Window}}" Value="400">
                        <Setter Property="Orientation" Value="Vertical"/>
                    </DataTrigger>
                    <DataTrigger Binding="{Binding ActualWidth, RelativeSource={RelativeSource AncestorType=Window}}" Value="500">
                        <Setter Property="Orientation" Value="Vertical"/>
                    </DataTrigger>
                </Style.Triggers>
            </Style>

            <!-- Định nghĩa Style cho StackPanel responsive cho buttons -->
            <Style x:Key="ResponsiveButtonPanelStyle" TargetType="StackPanel">
                <Setter Property="Orientation" Value="Horizontal"/>
                <Style.Triggers>
                    <!-- Khi chiều rộng nhỏ hơn chiều cao (chế độ dọc), đổi sang dọc -->
                    <DataTrigger Binding="{Binding ActualWidth, RelativeSource={RelativeSource AncestorType=Window}}" Value="300">
                        <Setter Property="Orientation" Value="Vertical"/>
                    </DataTrigger>
                    <DataTrigger Binding="{Binding ActualWidth, RelativeSource={RelativeSource AncestorType=Window}}" Value="400">
                        <Setter Property="Orientation" Value="Vertical"/>
                    </DataTrigger>
                    <DataTrigger Binding="{Binding ActualWidth, RelativeSource={RelativeSource AncestorType=Window}}" Value="500">
                        <Setter Property="Orientation" Value="Vertical"/>
                    </DataTrigger>
                </Style.Triggers>
            </Style>
        </Grid.Resources>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="542*"/>
            <ColumnDefinition Width="97*"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="110"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <!-- Header Section -->
        <Border x:Name="HeaderBorder" Grid.Row="0" Background="#FF1F1F1F" CornerRadius="6" Padding="10" Margin="0,0,19,20" Grid.ColumnSpan="2">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" Margin="0,0,20,0">
                    <TextBlock Text="GMTPC Tools"
                                FontSize="22"
                                FontWeight="Bold"
                                Foreground="Yellow"
                                Margin="0,0,10,5" Height="29" Width="138"/>
                </StackPanel>
                <StackPanel Grid.Column="1" Orientation="Vertical" VerticalAlignment="Top" HorizontalAlignment="Stretch" Margin="0,0,0,0">
                    <Grid VerticalAlignment="Center" Margin="0,0,0,6">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Width="180" Text="Tác giả: Ma Minh Toàn 1993" FontSize="13" Foreground="LightGreen" VerticalAlignment="Center"/>
                        <Button x:Name="BtnDonate"
                                Grid.Column="1"
                                Content="Ủng hộ tác giả"
                                Background="DarkGreen"
                                BorderBrush="#FF005FB8"
                                Foreground="#FFE6E6E6"
                                FontSize="9"
                                Padding="4,2"
                                Margin="0,0,12,0"
                                HorizontalAlignment="Left"
                                Click="BtnExit_Click" Height="22" Width="90"/>
                        <TextBlock Grid.Column="2"
                                   Text="Windows Defender: không cần tắt, Antivirus khác: phải tắt."
                                   FontSize="15"
                                   Foreground="Cyan"
                                   TextWrapping="Wrap"
                                   MinWidth="0"
                                   VerticalAlignment="Center"/>
                    </Grid>
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <StackPanel Orientation="Vertical" VerticalAlignment="Center" Margin="0,0,10,0">
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                            <TextBlock Text="Scale DPI:" FontSize="10" Foreground="#FFE6E6E6" Margin="0,0,2,0" VerticalAlignment="Center"/>
                            <Button x:Name="BtnDPIMinus" Content="-" Width="22" Height="18" FontSize="10" Margin="0,0,2,0" Click="BtnDPIMinus_Click" VerticalAlignment="Center"/>
                            <ComboBox x:Name="CboDPIValue" Width="52" Height="18" FontSize="10" SelectedValuePath="Content" SelectionChanged="CboDPIValue_SelectionChanged" Margin="0,0,2,0"
                                      HorizontalContentAlignment="Center" VerticalContentAlignment="Center">
                                <ComboBox.ItemContainerStyle>
                                    <Style TargetType="{x:Type ComboBoxItem}">
                                        <Setter Property="HorizontalContentAlignment" Value="Center"/>
                                        <Setter Property="VerticalContentAlignment" Value="Center"/>
                                    </Style>
                                </ComboBox.ItemContainerStyle>
                                <ComboBoxItem Content="50%"/>
                                <ComboBoxItem Content="60%"/>
                                <ComboBoxItem Content="70%"/>
                                <ComboBoxItem Content="80%"/>
                                <ComboBoxItem Content="90%"/>
                                <ComboBoxItem Content="100%"/>
                                <ComboBoxItem Content="110%"/>
                                <ComboBoxItem Content="120%"/>
                                <ComboBoxItem Content="130%"/>
                                <ComboBoxItem Content="140%"/>
                                <ComboBoxItem Content="150%"/>
                                <ComboBoxItem Content="160%"/>
                                <ComboBoxItem Content="170%"/>
                                <ComboBoxItem Content="180%"/>
                                <ComboBoxItem Content="200%"/>
                            </ComboBox>
                            <Button x:Name="BtnDPIPlus" Content="+" Width="22" Height="18" FontSize="10" Click="BtnDPIPlus_Click" VerticalAlignment="Center"/>
                            </StackPanel>
                        </StackPanel>
                        <StackPanel Orientation="Vertical" VerticalAlignment="Center" Margin="10,0,0,0">
                            <TextBlock Text="Dark Theme Windows" FontSize="10" Foreground="#FFE6E6E6" HorizontalAlignment="Center" Margin="0,0,0,2"/>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                                <ToggleButton x:Name="TglTheme"
                                              Style="{StaticResource ThemeToggleSwitchStyle}"
                                              HorizontalAlignment="Center"
                                              Click="TglTheme_Click"/>
                                <TextBlock x:Name="BuildNumberHeaderTextBlock"
                                           Text="Build: ----"
                                           FontSize="12"
                                           Foreground="#FFF0F0F0"
                                           VerticalAlignment="Center"
                                           Margin="10,0,0,0"/>
                            </StackPanel>
                        </StackPanel>
                    </StackPanel>
                </StackPanel>
            </Grid>
        </Border>
        <!-- Checkboxes Section with ScrollViewer -->
        <Border x:Name="TabHostBorder" Grid.Row="1" Background="#FF1F1F1F" CornerRadius="6" Padding="10" Margin="0,0,19,10" Grid.ColumnSpan="2">
            <TabControl x:Name="MainTabControl" Background="Yellow" BorderBrush="#FF7A7A7A" SelectionChanged="MainTabControl_SelectionChanged">
                <TabControl.Resources>
                    <!-- Style cho TabItem - nhỏ gọn, 1 hàng -->
                    <Style TargetType="TabItem">
                        <Setter Property="Background" Value="#FF2B2B2B"/>
                        <Setter Property="Foreground" Value="NavajoWhite"/>
                        <Setter Property="FontSize" Value="10.5"/>
                        <Setter Property="Padding" Value="5,2"/>
                        <Setter Property="MinHeight" Value="21"/>
                        <Setter Property="MinWidth" Value="50"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="TabItem">
                                    <Border Name="Border" Background="{TemplateBinding Background}"
                                            BorderBrush="{TemplateBinding BorderBrush}"
                                            BorderThickness="1,1,1,0"
                                            CornerRadius="3,3,0,0"
                                            Margin="0,0,-1,0">
                                        <ContentPresenter x:Name="ContentSite"
                                                          VerticalAlignment="Center"
                                                          HorizontalAlignment="Center"
                                                          ContentSource="Header"
                                                          Margin="5,2"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsSelected" Value="True">
                                            <Setter TargetName="Border" Property="Background" Value="#FF1F1F1F"/>
                                            <Setter Property="Foreground" Value="#FFFFFFFF"/>
                                        </Trigger>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="Border" Property="Background" Value="#FF3E3E3E"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </TabControl.Resources>
                <TabControl.Template>
                    <ControlTemplate TargetType="TabControl">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <TabPanel x:Name="HeaderPanel"
                                      Grid.Row="0"
                                      Panel.ZIndex="1"
                                      IsItemsHost="True"
                                      KeyboardNavigation.TabIndex="1"
                                      Background="Transparent"/>
                            <Border x:Name="ContentPanel"
                                    Grid.Row="1"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    KeyboardNavigation.TabIndex="2"
                                    KeyboardNavigation.TabNavigation="Local"
                                    KeyboardNavigation.DirectionalNavigation="Contained">
                                <ContentPresenter x:Name="PART_SelectedContentHost"
                                                  ContentSource="SelectedContent"
                                                  Margin="{TemplateBinding Padding}"
                                                  ContentTemplate="{TemplateBinding SelectedContentTemplate}"/>
                            </Border>
                        </Grid>
                    </ControlTemplate>
                </TabControl.Template>
                <TabItem Header="System Information">
                    <ScrollViewer VerticalScrollBarVisibility="Disabled" HorizontalScrollBarVisibility="Disabled" Background="#FF1F1F1F">
                        <UniformGrid Columns="2" Rows="2" Margin="8">
                            <Border BorderBrush="#FF295E8A" BorderThickness="1" CornerRadius="5" Padding="10" Margin="0,0,6,6" Background="#FF183247">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="*"/>
                                    </Grid.RowDefinitions>
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                        <TextBlock Text="GPU" FontSize="15" FontWeight="Bold" Foreground="#FFFFFFFF" FontFamily="Consolas"/>
                                    </StackPanel>
                                    <Border Grid.Row="1" Background="#FF102536" BorderBrush="#FF295E8A" BorderThickness="1" CornerRadius="4" Padding="10">
                                        <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto">
                                            <TextBlock x:Name="TbGPU" Text="..." Foreground="#FFE6E6E6" FontFamily="Consolas" FontSize="15" TextWrapping="NoWrap"/>
                                        </ScrollViewer>
                                    </Border>
                                </Grid>
                            </Border>

                            <Border BorderBrush="#FF6B4FA3" BorderThickness="1" CornerRadius="5" Padding="10" Margin="6,0,0,6" Background="#FF2D2546">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="*"/>
                                    </Grid.RowDefinitions>
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                        <TextBlock Text="CPU" FontSize="15" FontWeight="Bold" Foreground="#FFFFFFFF" FontFamily="Consolas"/>
                                    </StackPanel>
                                    <Border Grid.Row="1" Background="#FF211A35" BorderBrush="#FF6B4FA3" BorderThickness="1" CornerRadius="4" Padding="10">
                                        <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto">
                                            <TextBlock x:Name="TbCPU" Text="..." Foreground="#FFE6E6E6" FontFamily="Consolas" FontSize="15" TextWrapping="NoWrap"/>
                                        </ScrollViewer>
                                    </Border>
                                </Grid>
                            </Border>

                            <Border BorderBrush="#FF43845D" BorderThickness="1" CornerRadius="5" Padding="10" Margin="0,6,6,0" Background="#FF1F3B2C">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="*"/>
                                    </Grid.RowDefinitions>
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                        <TextBlock Text="RAM" FontSize="15" FontWeight="Bold" Foreground="#FFFFFFFF" FontFamily="Consolas"/>
                                    </StackPanel>
                                    <Border Grid.Row="1" Background="#FF172B20" BorderBrush="#FF43845D" BorderThickness="1" CornerRadius="4" Padding="10">
                                        <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto">
                                            <TextBlock x:Name="TbRAM" Text="..." Foreground="#FFE6E6E6" FontFamily="Consolas" FontSize="15" TextWrapping="NoWrap"/>
                                        </ScrollViewer>
                                    </Border>
                                </Grid>
                            </Border>

                            <Border BorderBrush="#FF9B5A45" BorderThickness="1" CornerRadius="5" Padding="10" Margin="6,6,0,0" Background="#FF47291F">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="*"/>
                                    </Grid.RowDefinitions>
                                    <StackPanel x:Name="HardwareHeaderPanel" Orientation="Horizontal" Margin="0,0,0,8">
                                        <TextBlock Text="Mainboard" FontSize="15" FontWeight="Bold" Foreground="#FFFFFFFF" FontFamily="Consolas"/>
                                    </StackPanel>
                                    <Border Grid.Row="1" Background="#FF321C16" BorderBrush="#FF9B5A45" BorderThickness="1" CornerRadius="4" Padding="10">
                                        <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto">
                                            <TextBlock x:Name="TbMainboard" Text="..." Foreground="#FFE6E6E6" FontFamily="Consolas" FontSize="15" TextWrapping="NoWrap"/>
                                        </ScrollViewer>
                                    </Border>
                                </Grid>
                            </Border>
                        </UniformGrid>
                    </ScrollViewer>
                </TabItem>

                <TabItem Header="Popular">
                    <ScrollViewer VerticalScrollBarVisibility="Disabled" HorizontalScrollBarVisibility="Disabled" Background="#FF1F1F1F">
                        <WrapPanel x:Name="CheckBoxPanel" Orientation="Horizontal" HorizontalAlignment="Stretch" Style="{StaticResource ResponsiveWrapPanelStyle}">
                            <Border BorderBrush="#FF7A7A7A" BorderThickness="1" CornerRadius="5" Width="206">
                                <StackPanel>
                                    <CheckBox x:Name="ChkInstallIDM" Content="IDM" Width="175" Height="34" Click="ChkInstallIDM_Click" Margin="3" MouseEnter="Checkbox_MouseEnter"/>
                                    <StackPanel Orientation="Horizontal" Margin="3,0">
                                        <Button x:Name="BtnFixIDMExtension" Content="Fix extension IDM" Width="104" Height="22" Click="BtnFixIDMExtension_Click" Margin="6,0,3,3"/>
                                        <Button x:Name="BtnCrackIDM" Content="Cờ rắck IDM" Width="79" Height="22" Click="BtnCrackIDM_Click" Margin="3,0,0,3"/>
                                    </StackPanel>
                                </StackPanel>
                            </Border>
                            <Border BorderBrush="#FF7A7A7A" BorderThickness="1" CornerRadius="5" Width="205">
                                <StackPanel>
                                    <CheckBox x:Name="ChkInstallBID" Content="Bulk Image Downloader" Width="175" Height="34" Click="ChkInstallBID_Click" Margin="3" MouseEnter="Checkbox_MouseEnter"/>
                                    <Button x:Name="BtnRunBIDActivation" Content="Run BID Activation" Width="155" Height="22" Click="BtnRunBIDActivation_Click" Margin="9,0,3,3"/>
                                </StackPanel>
                            </Border>
                            <CheckBox x:Name="ChkInstallNeatDM" Content="Neat Download Manager" Width="200" Height="34" Click="ChkInstallNeatDM_Click" MouseEnter="Checkbox_MouseEnter"/>
                            <CheckBox x:Name="ChkInstallWinRAR" Content="Winrar" Width="200" Height="34" Click="ChkInstallWinRAR_Click" MouseEnter="Checkbox_MouseEnter"/>
                            <CheckBox x:Name="ChkActivateWindows" Content="Tự động kích hoạt Windows" Width="200" Height="34" Click="ChkActivateWindows_Click" MouseEnter="Checkbox_MouseEnter"/>
                            <CheckBox x:Name="ChkPauseWindowsUpdate" Content="Pause Windows Update" Width="200" Height="34" Click="ChkPauseWindowsUpdate_Click" MouseEnter="Checkbox_MouseEnter"/>
                            <CheckBox x:Name="ChkVcredist" Content="Vcredist 2005-2022" Width="200" Height="34" Click="ChkVcredist_Click" MouseEnter="Checkbox_MouseEnter"/>
                            <CheckBox x:Name="ChkDirectX" Content="Directx" Width="200" Height="34" Click="ChkDirectX_Click" MouseEnter="Checkbox_MouseEnter"/>
                            <CheckBox x:Name="ChkJava" Content="Java" Width="200" Height="34" Click="ChkJava_Click" MouseEnter="Checkbox_MouseEnter"/>
                            <CheckBox x:Name="ChkOpenAL" Content="OpenAL" Width="200" Height="34" Click="ChkOpenAL_Click" MouseEnter="Checkbox_MouseEnter"/>
                            <CheckBox x:Name="ChkRevoUninstaller" Content="Revo Uninstaller" Width="200" Height="34" Click="ChkRevoUninstaller_Click" MouseEnter="Checkbox_MouseEnter"/>
                            <CheckBox x:Name="ChkInstallZalo" Content="Zalo" Width="200" Height="34" Click="ChkInstallZalo_Click" MouseEnter="Checkbox_MouseEnter"/>
                        </WrapPanel>
                    </ScrollViewer>
                </TabItem>
                <TabItem Header="Office">
                    <ScrollViewer VerticalScrollBarVisibility="Disabled" HorizontalScrollBarVisibility="Disabled" Background="#FF1F1F1F">
                        <WrapPanel x:Name="OfficePanel" Orientation="Horizontal" HorizontalAlignment="Stretch" Style="{StaticResource ResponsiveWrapPanelStyle}">
                            <CheckBox x:Name="ChkOfficeToolPlus" Content="Office Tool Plus" Width="200" Height="34" Click="ChkOfficeToolPlus_Click" Margin="2" MouseEnter="Checkbox_MouseEnter"/>
                            <CheckBox x:Name="ChkOfficeSoftmaker" Content="Office Softmaker" Width="200" Height="34" Click="ChkOfficeSoftmaker_Click" Margin="2" MouseEnter="Checkbox_MouseEnter"/>
                            <CheckBox x:Name="ChkActivateOffice" Content="Tự động kích hoạt Office" Width="200" Height="34" Click="ChkActivateOffice_Click" Margin="2" MouseEnter="Checkbox_MouseEnter"/>
                            <CheckBox x:Name="ChkGMTPCFonts" Content="GMTPC Fonts" Width="200" Height="34" Click="ChkGMTPCFonts_Click" Margin="2" MouseEnter="Checkbox_MouseEnter"/>
                            <CheckBox x:Name="ChkNotepadPlusPlus" Content="Notepad++" Width="200" Height="34" Click="ChkNotepadPlusPlus_Click" Margin="2" MouseEnter="Checkbox_MouseEnter"/>
                        </WrapPanel>
                    </ScrollViewer>
                </TabItem>
                <TabItem Header="Subtitle">
                    <ScrollViewer VerticalScrollBarVisibility="Disabled" HorizontalScrollBarVisibility="Disabled" Background="#FF1F1F1F">
                        <WrapPanel x:Name="SubtitlePanel" Orientation="Horizontal" HorizontalAlignment="Stretch" Style="{StaticResource ResponsiveWrapPanelStyle}">
                            <Border BorderBrush="#FF555555" BorderThickness="1" CornerRadius="3" Margin="2" Padding="5" Background="#FF2A2A2A">
                                <StackPanel Orientation="Vertical">
                                    <CheckBox x:Name="ChkSubtitleEdit" Content="Subtitle Edit" Width="180" Height="30" Click="ChkSubtitleEdit_Click" MouseEnter="Checkbox_MouseEnter" Margin="0,0,0,3"/>
